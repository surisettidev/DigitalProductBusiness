# Copy to .env (NEVER commit .env)
# These are Cloudflare Pages environment variables (Settings → Environment
# variables → Production). They are read by Pages Functions — never the browser.

# ── Razorpay (PRIMARY payment gateway) ─────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx          # publishable key (also sent to browser)
RAZORPAY_KEY_SECRET=                       # SECRET — order creation + signature verify
RAZORPAY_WEBHOOK_SECRET=                   # set in Razorpay Dashboard → Webhooks; must match

# ── Brevo (transactional delivery email + newsletter) ──────────
BREVO_API_KEY=xsmtpsib-xxxxxxxx
BREVO_LIST_ID=2
FROM_EMAIL=surisetti.dev@gmail.com         # verified Brevo sender
SUPPORT_EMAIL=surisetti.dev@gmail.com

# ── Product delivery links (JSON map slug → download URL) ──────
# Until set, customers see "link arriving by email" and you deliver manually.
# Example:
# DELIVERY_LINKS={"ai-freelancer":"https://drive.google.com/uc?id=...","pricing-guide":"https://..."}
DELIVERY_LINKS={}

# ── Admin dashboard (server-side auth) ─────────────────────────
ADMIN_PASSWORD=                            # pick a long random passphrase
ADMIN_TOKEN_SECRET=                        # any long random string (signs login tokens)

# ── GitHub sale logging (fine-grained PAT, contents:rw on this repo) ──
GITHUB_PAT=
GITHUB_OWNER=surisettidev
GITHUB_REPO=DigitalProductBusiness

# ── Misc ───────────────────────────────────────────────────────
SITE_URL=https://freelance-os.pages.dev

# Payhip (legacy / optional fallback)
PAYHIP_WEBHOOK_SECRET=

# Free AI APIs — daily content generation only
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
