# Copy to .env (NEVER commit .env)
# These are loaded by Cloudflare Pages Functions / GitHub Actions — not by the browser.

BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_ID=2

PAYHIP_WEBHOOK_SECRET=set_in_payhip_dashboard

# Razorpay — phase 2 only
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Your live site URL (used by Payhip webhook to write to tables/sales)
SITE_URL=https://digital-product-business.pages.dev

# GitHub — fine-grained PAT scoped to this repo only
# Also add this as repo secret named GITHUBPAT in GitHub → Settings → Secrets
GITHUB_PAT=
GITHUB_OWNER=surisettidev
GITHUB_REPO=DigitalProductBusiness

# Free AI APIs — daily content generation only
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
